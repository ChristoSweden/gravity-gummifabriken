# ── Required ──
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# ── Push Notifications (optional) ──
VITE_VAPID_PUBLIC_KEY="YOUR_VAPID_PUBLIC_KEY"

# ── App Branding (optional — defaults shown) ──
# VITE_APP_NAME="Gravity"
# VITE_LOCATION_NAME="Gummifabriken"

# ── Geofence (optional — defaults to Gummifabriken, Värnamo) ──
# VITE_VENUE_LAT="57.1826"
# VITE_VENUE_LNG="13.9456"
# VITE_PRESENCE_RADIUS_M="200"
# VITE_RADAR_RADIUS="150m"

# ── WiFi Presence Detection (optional) ──
# Public IP(s) of the venue WiFi — comma-separated
# Find yours: connect to venue WiFi and visit whatismyip.com
# VENUE_PUBLIC_IPS="203.0.113.42,203.0.113.43"

# ── Admin (comma-separated emails) ──
# VITE_ADMIN_EMAILS="admin@example.com"
